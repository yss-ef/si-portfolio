<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="product_allergens_info" inherit_id="website_sale.product">
        <xpath expr="//div[@id='product_attributes_simple']" position="after">
            <div t-if="product.allergen_ids" class="mt-3 p-2 border rounded bg-light">
                <h6 class="text-danger"><i class="fa fa-exclamation-triangle"/> Informations Allergènes</h6>
                <ul class="list-inline mb-0">
                    <t t-foreach="product.allergen_ids" t-as="allergen">
                        <li class="list-inline-item badge badge-pill" style="background-color: #ffeeba; color: #856404; padding: 5px 10px; border: 1px solid #ffeeba; border-radius: 10px;">
                            <span t-field="allergen.name"/>
                        </li>
                    </t>
                </ul>
            </div>
        </xpath>
    </template>
</odoo>
