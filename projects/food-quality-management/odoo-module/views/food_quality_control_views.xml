<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="food_quality_control_view_kanban" model="ir.ui.view">
        <field name="name">food.quality.control.kanban</field>
        <field name="model">food.quality.control</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" quick_create="false">
                <field name="name"/>
                <field name="product_id"/>
                <field name="inspection_date"/>
                <field name="state"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click shadow-sm border-left-4 #{record.state.raw_value == 'passed' ? 'border-success' : (record.state.raw_value == 'failed' ? 'border-danger' : 'border-info')}">
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <div class="text-muted">
                                    <field name="product_id"/>
                                </div>
                                <div class="mt-2">
                                    <i class="fa fa-calendar" title="Date"/> <field name="inspection_date"/>
                                </div>
                                <div class="mt-2 text-right">
                                    <field name="state" widget="label_selection" options="{'classes': {'draft': 'info', 'passed': 'success', 'failed': 'danger'}}"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="food_quality_control_view_search" model="ir.ui.view">
        <field name="name">food.quality.control.search</field>
        <field name="model">food.quality.control</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="lot_id"/>
                <field name="product_id"/>
                <filter string="À faire" name="filter_to_do" domain="[('state', 'in', ('draft', 'in_progress'))]"/>
                <filter string="Conformes" name="filter_passed" domain="[('state', '=', 'passed')]"/>
                <filter string="Non Conformes" name="filter_failed" domain="[('state', '=', 'failed')]"/>
                <separator/>
                <filter string="Produits Périssables" name="filter_perishable" domain="[('product_id.product_tmpl_id.is_perishable', '=', True)]"/>
                <group expand="0" string="Regrouper par">
                    <filter string="Produit" name="group_by_product" context="{'group_by': 'product_id'}"/>
                    <filter string="État" name="group_by_state" context="{'group_by': 'state'}"/>
                    <filter string="Inspecteur" name="group_by_inspector" context="{'group_by': 'inspector_id'}"/>
                    <filter string="Mois" name="group_by_month" context="{'group_by': 'inspection_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="food_quality_control_view_tree" model="ir.ui.view">
        <field name="name">food.quality.control.tree</field>
        <field name="model">food.quality.control</field>
        <field name="arch" type="xml">
            <tree decoration-info="state == 'draft'" decoration-success="state == 'passed'" decoration-danger="state == 'failed'">
                <field name="name"/>
                <field name="lot_id"/>
                <field name="product_id"/>
                <field name="inspection_date"/>
                <field name="recorded_temperature"/>
                <field name="state" widget="badge" decoration-success="state == 'passed'" decoration-danger="state == 'failed'"/>
            </tree>
        </field>
    </record>

    <record id="food_quality_control_view_form" model="ir.ui.view">
        <field name="name">food.quality.control.form</field>
        <field name="model">food.quality.control</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_validate" type="object" string="Valider la conformité" class="oe_highlight" invisible="state != 'draft'" groups="gestion_alimentaire.group_food_quality_manager"/>
                    <button name="action_reject" type="object" string="Rejeter le lot" invisible="state != 'draft'" groups="gestion_alimentaire.group_food_quality_manager"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,passed,failed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="lot_id" readonly="state != 'draft'"/>
                            <field name="product_id"/>
                            <field name="inspection_date" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="target_temperature"/>
                            <field name="recorded_temperature" readonly="state != 'draft'"/>
                            <field name="inspector_id" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Observations">
                            <field name="notes" placeholder="Notes détaillées de l'inspection..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="food_quality_control_action" model="ir.actions.act_window">
        <field name="name">Contrôles Qualité</field>
        <field name="res_model">food.quality.control</field>
        <field name="view_mode">kanban,tree,form,pivot,graph</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Créez votre premier contrôle qualité !
            </p>
        </field>
    </record>

    <!-- Vues Allergènes -->
    <record id="food_allergen_view_tree" model="ir.ui.view">
        <field name="name">food.allergen.tree</field>
        <field name="model">food.allergen</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="name"/>
                <field name="description"/>
            </tree>
        </field>
    </record>

    <record id="food_allergen_action" model="ir.actions.act_window">
        <field name="name">Allergènes</field>
        <field name="res_model">food.allergen</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Menu Application -->
    <menuitem id="menu_food_root" name="Qualité Alimentaire" sequence="10" web_icon="base,static/description/settings.png"/>

    <!-- Sous-menu Opérations -->
    <menuitem id="menu_food_quality_control" name="Contrôles Qualité" parent="menu_food_root" action="food_quality_control_action" sequence="10"/>

    <!-- Sous-menu Configuration -->
    <menuitem id="menu_food_config" name="Configuration" parent="menu_food_root" sequence="100" groups="gestion_alimentaire.group_food_quality_manager"/>
    <menuitem id="menu_food_allergen" name="Allergènes" parent="menu_food_config" action="food_allergen_action" sequence="10"/>
    </odoo>

