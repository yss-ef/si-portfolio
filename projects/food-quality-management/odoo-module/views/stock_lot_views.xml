<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_stock_lot_form_inherit_food" model="ir.ui.view">
        <field name="name">stock.lot.form.inherit.food</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="stock.view_production_lot_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_quality_checks" type="object" class="oe_stat_button" icon="fa-check-circle text-success">
                    <field name="quality_check_count" widget="statinfo" string="Quality Checks"/>
                </button>
            </xpath>
            <xpath expr="//group[@name='main_group']" position="after">
                <group string="Sécurité Alimentaire">
                    <field name="last_control_date"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
