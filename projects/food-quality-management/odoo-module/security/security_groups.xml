<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_food_management" model="ir.module.category">
        <field name="name">Gestion Alimentaire</field>
        <field name="sequence">10</field>
    </record>

    <record id="group_food_quality_user" model="res.groups">
        <field name="name">Utilisateur Qualité</field>
        <field name="category_id" ref="module_category_food_management"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_food_quality_manager" model="res.groups">
        <field name="name">Manager Qualité</field>
        <field name="category_id" ref="module_category_food_management"/>
        <field name="implied_ids" eval="[(4, ref('group_food_quality_user'))]"/>
    </record>
</odoo>
