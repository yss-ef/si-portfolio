<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <!-- Formulaire de l'étudiant -->
        <record id="etudiant_form_view" model="ir.ui.view">
            <field name="name">etudiant.form.view</field>
            <field name="model">gestion.etudiant</field>
            <field name="arch" type="xml">
                <form string="Étudiant">
                    <sheet>
                        <field name="photo" widget="image" class="oe_avatar"/>
                        <div class="oe_title">
                            <h1>
                                <field name="num_etudiant" placeholder="Numéro Étudiant"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="prenom"/>
                                <field name="sexe"/>
                            </group>
                            <group>
                                <field name="date_naissance"/>
                                <field name="email"/>
                                <field name="telephone"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Cours suivis">
                                <field name="cours_ids">
                                    <tree>
                                        <field name="code"/>
                                        <field name="name"/>
                                        <field name="professeur_id"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Liste des étudiants -->
        <record id="etudiant_tree_view" model="ir.ui.view">
            <field name="name">etudiant.tree.view</field>
            <field name="model">gestion.etudiant</field>
            <field name="arch" type="xml">
                <tree string="Étudiants">
                    <field name="num_etudiant"/>
                    <field name="name"/>
                    <field name="prenom"/>
                    <field name="date_naissance"/>
                    <field name="email"/>
                    <field name="telephone"/>
                    <field name="sexe"/>
                </tree>
            </field>
        </record>

        <!-- Vue Kanban des étudiants -->
        <record id="etudiant_kanban_view" model="ir.ui.view">
            <field name="name">etudiant.kanban.view</field>
            <field name="model">gestion.etudiant</field>
            <field name="arch" type="xml">
                <kanban>
                    <field name="id"/>
                    <field name="name"/>
                    <field name="prenom"/>
                    <field name="num_etudiant"/>
                    <field name="sexe"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_global_click o_kanban_record_has_image_fill">
                                <div class="o_kanban_image d-none d-md-block"
                                     t-attf-style="background-image:url('#{kanban_image('gestion.etudiant', 'photo', record.id.raw_value)}')"/>
                                <div class="oe_kanban_details">
                                    <strong class="o_kanban_record_title">
                                        <field name="prenom"/> <field name="name"/>
                                    </strong>
                                    <ul>
                                        <li>N°: <field name="num_etudiant"/></li>
                                        <li>Sexe: <field name="sexe"/></li>
                                    </ul>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Action pour ouvrir la liste des étudiants -->
        <record id="etudiant_action" model="ir.actions.act_window">
            <field name="name">Étudiants</field>
            <field name="res_model">gestion.etudiant</field>
            <field name="view_mode">kanban,tree,form</field>
        </record>

        <!-- Menu pour accéder à la liste des étudiants -->
        <menuitem id="menu_gestion_etudiants" name="Gestion des étudiants" sequence="10"/>
        <menuitem id="menu_etudiant" name="Étudiants" parent="menu_gestion_etudiants" action="etudiant_action" sequence="10"/>
    </data>
</odoo>
